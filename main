<script>
/* ════════════════════════════════════════
   XE STUDIO — MAIN JS
   All orders & contact messages are sent
   automatically to brajd34@gmail.com
════════════════════════════════════════ */

const OWNER_EMAIL = "brajd34@gmail.com";

// ── CURSOR ──
const cur = document.getElementById('cur');
const curt = document.getElementById('curt');
let mx=0,my=0,tx=0,ty=0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cur.style.left = mx + 'px';
  cur.style.top = my + 'px';
});
(function animCur(){
  tx += (mx-tx)*.14; ty += (my-ty)*.14;
  curt.style.left = tx + 'px'; curt.style.top = ty + 'px';
  requestAnimationFrame(animCur);
})();
document.querySelectorAll('a,button,.sopt,.mopt,.vc,.bp,.bs,.srpl,.baht').forEach(el => {
  el.addEventListener('mouseenter', () => cur.style.transform = 'translate(-50%,-50%) scale(2)');
  el.addEventListener('mouseleave', () => cur.style.transform = 'translate(-50%,-50%) scale(1)');
});

// ── PARTICLES ──
const cvs = document.getElementById('pc');
const ctx = cvs.getContext('2d');
function rz(){ cvs.width = innerWidth; cvs.height = innerHeight; }
rz(); addEventListener('resize', rz);
const pts = [];
class Pt {
  constructor(){ this.rs(); }
  rs(){ this.x=Math.random()*cvs.width; this.y=Math.random()*cvs.height; this.s=Math.random()*1.7+.4; this.vx=(Math.random()-.5)*.38; this.vy=-Math.random()*.65-.15; this.op=Math.random()*.42+.1; this.life=1; this.dec=Math.random()*.0022+.001; }
  upd(){ this.x+=this.vx; this.y+=this.vy; this.life-=this.dec; if(this.life<=0) this.rs(); }
  drw(){ ctx.save(); ctx.globalAlpha=this.life*this.op; ctx.fillStyle=`hsl(${Math.random()<.88?0:15},100%,${50+Math.random()*28}%)`; ctx.shadowBlur=5; ctx.shadowColor='#ff0000'; ctx.beginPath(); ctx.arc(this.x,this.y,this.s,0,Math.PI*2); ctx.fill(); ctx.restore(); }
}
for(let i=0;i<95;i++) pts.push(new Pt());
(function ap(){ ctx.clearRect(0,0,cvs.width,cvs.height); pts.forEach(p=>{p.upd();p.drw();}); requestAnimationFrame(ap); })();

// ── INTRO SPARKS ──
const ipts = document.getElementById('ipts');
for(let i=0;i<44;i++){
  const s = document.createElement('div'); s.className='sp';
  s.style.left = Math.random()*100+'%';
  s.style.width = (Math.random()*3+1)+'px'; s.style.height = s.style.width;
  s.style.animationDelay = Math.random()*3+'s';
  s.style.animationDuration = (1.8+Math.random()*2.2)+'s';
  ipts.appendChild(s);
}

// ── WITCH SPARKS ──
const wsps = document.getElementById('wsps');
for(let i=0;i<22;i++){
  const s = document.createElement('div'); s.className='wsp';
  const a=Math.random()*360, d=80+Math.random()*175;
  s.style.left = (42+Math.cos(a*Math.PI/180)*12)+'%';
  s.style.bottom = (18+Math.random()*52)+'%';
  s.style.setProperty('--tx', (Math.cos(a*Math.PI/180)*d)+'px');
  s.style.setProperty('--ty', (Math.sin(a*Math.PI/180)*d-75)+'px');
  s.style.animationDuration = (1.2+Math.random()*1.7)+'s';
  s.style.animationDelay = (Math.random()*2)+'s';
  wsps.appendChild(s);
}

// ── ENTER SITE ──
function enterSite(){
  const nm = (document.getElementById('uinp').value.trim()||'Visitor').toUpperCase();
  document.getElementById('nusr').textContent = nm;
  document.getElementById('intro').classList.add('exit');
  setTimeout(()=>{
    document.getElementById('intro').style.display='none';
    const m = document.getElementById('main');
    m.style.display='block';
    setTimeout(()=>{ m.classList.add('vis'); initReveal(); }, 40);
  }, 820);
}
document.getElementById('enterbtn').addEventListener('click', enterSite);
document.getElementById('uinp').addEventListener('keypress', e=>{ if(e.key==='Enter') enterSite(); });

// ── NAVBAR SCROLL ──
addEventListener('scroll', ()=>{
  document.getElementById('nav').classList.toggle('sc', scrollY>50);
});

// ── WITCH PARALLAX ──
const wi = document.getElementById('wimg');
addEventListener('scroll', ()=>{
  const hy = document.getElementById('hero').offsetHeight;
  if(scrollY < hy && wi) {
    wi.style.transform = `translateY(${scrollY*.16}px) translateX(${(scrollY/hy)*22}px)`;
  }
});

// ── SCROLL REVEAL ──
function initReveal(){
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('vis'); });
  }, {threshold:.07, rootMargin:'0px 0px -36px 0px'});
  document.querySelectorAll('.rv').forEach(el=>obs.observe(el));
}
initReveal();

// ── MODAL ──
function openMod(t){
  document.getElementById('mtit').textContent = t;
  document.getElementById('vmod').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeMod(){
  document.getElementById('vmod').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('vmod').addEventListener('click', e=>{ if(e.target===document.getElementById('vmod')) closeMod(); });
addEventListener('keydown', e=>{ if(e.key==='Escape') closeMod(); });

// ── BEFORE/AFTER SLIDER ──
const basl=document.getElementById('basl'), bab=document.getElementById('bab'), baa=document.getElementById('baa'), baht=document.getElementById('baht');
let badr=false, bap=50;
function setBA(p){
  bap = Math.max(4,Math.min(96,p));
  bab.style.width = bap+'%';
  baa.style.left = bap+'%';
  baht.style.left = bap+'%';
}
setBA(50);
basl.addEventListener('mousedown', ()=>badr=true);
basl.addEventListener('touchstart', ()=>badr=true, {passive:true});
document.addEventListener('mousemove', e=>{ if(!badr) return; const r=basl.getBoundingClientRect(); setBA(((e.clientX-r.left)/r.width)*100); });
document.addEventListener('touchmove', e=>{ if(!badr) return; const r=basl.getBoundingClientRect(); setBA(((e.touches[0].clientX-r.left)/r.width)*100); }, {passive:true});
document.addEventListener('mouseup', ()=>badr=false);
document.addEventListener('touchend', ()=>badr=false);

// ── ORDER DATA ──
const od = {style:'',name:'',email:'',phone:'',links:'',desc:'',length:'',platform:'',ref:'',mood:'',song:'',notes:''};
let curSt = 1;

document.querySelectorAll('.sopt').forEach(o=>{
  o.addEventListener('click', function(){
    document.querySelectorAll('.sopt').forEach(x=>x.classList.remove('sel'));
    this.classList.add('sel'); od.style=this.dataset.v;
  });
});
document.querySelectorAll('.mopt').forEach(o=>{
  o.addEventListener('click', function(){
    document.querySelectorAll('.mopt').forEach(x=>x.classList.remove('sel'));
    this.classList.add('sel'); od.mood=this.dataset.v;
  });
});

function goStep(n){
  if(curSt===1 && !od.style){ alert('Please select an editing style!'); return; }
  if(curSt===2){
    od.name=document.getElementById('oname').value.trim();
    od.email=document.getElementById('oemail').value.trim();
    od.phone=document.getElementById('ophone').value.trim();
    od.links=document.getElementById('olinks').value.trim();
    if(!od.name||!od.email){ alert('Please enter your name and email!'); return; }
    if(!od.email.includes('@')){ alert('Please enter a valid email address!'); return; }
  }
  if(curSt===3){
    od.desc=document.getElementById('odesc').value.trim();
    od.length=document.getElementById('olen').value;
    od.platform=document.getElementById('oplat').value;
    od.ref=document.getElementById('oref').value.trim();
    if(!od.desc){ alert('Please describe the edit you want!'); return; }
  }
  if(curSt===4){
    od.song=document.getElementById('osong').value.trim();
    if(!od.mood){ alert('Please select a mood!'); return; }
    buildSum();
  }
  document.getElementById('st'+curSt).classList.remove('act');
  const prev = document.querySelector(`[data-s="${curSt}"]`);
  prev.classList.remove('act');
  if(n>curSt) prev.classList.add('done');
  else prev.classList.remove('done');
  curSt = n;
  document.getElementById('st'+curSt).classList.add('act');
  const cur2 = document.querySelector(`[data-s="${curSt}"]`);
  cur2.classList.add('act'); cur2.classList.remove('done');
  document.getElementById('order').scrollIntoView({behavior:'smooth',block:'start'});
}

function buildSum(){
  const rows=[['EDIT STYLE',od.style],['NAME',od.name],['EMAIL',od.email],['PHONE/WA',od.phone||'—'],['FILE LINKS',od.links||'—'],['LENGTH',od.length||'—'],['PLATFORM',od.platform||'—'],['MOOD',od.mood],['SONG REQUEST',od.song||'—']];
  document.getElementById('osum').innerHTML=
    '<div style="font-family:\'Orbitron\',monospace;font-size:.55rem;letter-spacing:.26em;color:var(--red);margin-bottom:.85rem;">ORDER SUMMARY</div>'+
    rows.map(([k,v])=>`<div class="osr"><span class="osk">${k}</span><span style="word-break:break-all;">${v}</span></div>`).join('');
}

// File upload
document.getElementById('upz').addEventListener('click', ()=>document.getElementById('finp').click());
document.getElementById('upz').addEventListener('dragover', e=>{ e.preventDefault(); document.getElementById('upz').classList.add('dov'); });
document.getElementById('upz').addEventListener('dragleave', ()=>document.getElementById('upz').classList.remove('dov'));
document.getElementById('upz').addEventListener('drop', e=>{ e.preventDefault(); document.getElementById('upz').classList.remove('dov'); showFiles(e.dataTransfer.files); });
document.getElementById('finp').addEventListener('change', e=>showFiles(e.target.files));
function showFiles(files){
  const l=document.getElementById('flist'); l.innerHTML='';
  Array.from(files).forEach(f=>{ const d=document.createElement('div'); d.className='fitem'; d.textContent='📁 '+f.name+' ('+(f.size/1024/1024).toFixed(2)+' MB)'; l.appendChild(d); });
}

// ── SUBMIT ORDER → EMAIL ──
function submitOrder(){
  od.notes = document.getElementById('onotes').value.trim();
  const btn = document.getElementById('subbtn');
  btn.disabled=true; btn.textContent='SENDING...';
  showLoader('SENDING YOUR ORDER TO BRAJ DEV...');

  const subject = `XE Studio ORDER — ${od.style} — ${od.name}`;
  const body = [
    'XE STUDIO — NEW ORDER',
    '========================',
    `Edit Style   : ${od.style}`,
    `Client Name  : ${od.name}`,
    `Email        : ${od.email}`,
    `Phone/WA     : ${od.phone||'—'}`,
    `File Links   : ${od.links||'—'}`,
    `Video Length : ${od.length||'—'}`,
    `Platform     : ${od.platform||'—'}`,
    `Mood         : ${od.mood}`,
    `Song Request : ${od.song||'—'}`,
    `References   : ${od.ref||'—'}`,
    '',
    'EDIT DESCRIPTION:',
    od.desc,
    '',
    'ADDITIONAL NOTES:',
    od.notes||'—',
    '',
    '========================',
    'Sent from XE Studio website',
    `Timestamp: ${new Date().toLocaleString()}`
  ].join('\n');

  // Open mailto (always reliable — opens default email client with full order)
  const ml = `mailto:${OWNER_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  
  setTimeout(()=>{
    window.location.href = ml;
    hideLoader();
    orderSuccess();
  }, 1200);
}

function orderSuccess(){
  document.getElementById('subbtn').style.display='none';
  const s = document.getElementById('osuc'); s.style.display='block';
  s.innerHTML=`
    <div style="font-size:2.4rem;margin-bottom:.85rem;">✅</div>
    <div style="font-family:'Orbitron',monospace;font-size:.72rem;letter-spacing:.2em;color:#00ff88;">ORDER SUBMITTED!</div>
    <div style="margin-top:.85rem;color:rgba(255,255,255,.48);font-size:.85rem;line-height:1.9;">
      Your order details have been prepared.<br>
      <strong style="color:rgba(255,140,140,.8);">Please send the email that just opened</strong> to complete.<br>
      <span style="color:rgba(255,100,100,.65);font-family:'Orbitron',monospace;font-size:.65rem;">${OWNER_EMAIL}</span><br>
      Braj Dev will contact you within 24 hours.
    </div>
    <div style="margin-top:1.2rem;display:flex;gap:.85rem;justify-content:center;flex-wrap:wrap;">
      <a href="https://wa.me/919329019647?text=${encodeURIComponent('Hi Braj Dev! I just submitted an order on XE Studio for: '+od.style+'. My name is '+od.name+'. Please confirm!')}" target="_blank" class="bp" style="text-decoration:none;font-size:.62rem;letter-spacing:.14em;clip-path:none;border-radius:2px;">💬 ALSO MSG ON WHATSAPP</a>
      <a href="mailto:${OWNER_EMAIL}" class="bs" style="text-decoration:none;font-size:.62rem;letter-spacing:.14em;clip-path:none;border-radius:2px;">📧 EMAIL DIRECTLY</a>
    </div>
  `;
}

// ── PREMIUM CODES ──
// XEBD69FUCK = free premium code given to people
const PCODES = ['XESTUDIO2024','BRAJDEV','HELLFIRE','SCARLET','XEBD69FUCK'];

function checkPrem(){
  const code = document.getElementById('prcode').value.trim().toUpperCase();
  const st = document.getElementById('prst');
  const pc = document.getElementById('premcnt');
  if(PCODES.includes(code)){
    st.className='prst ok';
    st.textContent='✅ CODE ACCEPTED — PREMIUM ACCESS UNLOCKED!';
    pc.style.display='block';
    setTimeout(()=>pc.scrollIntoView({behavior:'smooth',block:'nearest'}), 200);
  } else {
    st.className='prst err';
    st.textContent='❌ INVALID CODE — CONTACT BRAJ DEV FOR ACCESS';
    pc.style.display='none';
    setTimeout(()=>{ if(st.className.includes('err')) st.textContent=''; }, 3000);
  }
}


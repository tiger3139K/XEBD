// ── CONTACT FORM → EMAIL ──
function sendContact(){
  const name=document.getElementById('cn').value.trim();
  const email=document.getElementById('ce').value.trim();
  const subj=document.getElementById('cs').value.trim();
  const msg=document.getElementById('cm').value.trim();
  if(!name||!email||!msg){ alert('Please fill in all required fields!'); return; }
  if(!email.includes('@')){ alert('Please enter a valid email!'); return; }
  showLoader('SENDING YOUR MESSAGE...');

  const subject = subj||`Message from ${name} via XE Studio`;
  const body = `From: ${name}\nEmail: ${email}\n\nMessage:\n${msg}\n\n---\nSent from XE Studio contact form\n${new Date().toLocaleString()}`;
  const ml = `mailto:${OWNER_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

  setTimeout(()=>{
    window.location.href = ml;
    hideLoader();
    document.getElementById('cfrm').style.display='none';
    const s=document.getElementById('csuc'); s.style.display='block';
    s.innerHTML='✅<br>MESSAGE PREPARED!<br>Please send the email that opened.<br><small style="color:rgba(255,100,100,.6);font-family:\'Orbitron\',monospace;font-size:.6rem;">'+OWNER_EMAIL+'</small>';
  }, 1000);
}

// ── LOADER ──
function showLoader(txt){ document.getElementById('lovt').textContent=txt||'LOADING...'; document.getElementById('lovl').classList.add('show'); }
function hideLoader(){ document.getElementById('lovl').classList.remove('show'); }
</script>
